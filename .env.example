# ============================================
# Agent ROI Demo - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values.
# The setup.sh script can generate this for you interactively.

# === Snowflake Connection ===
SNOWFLAKE_ACCOUNT=your-account-locator
SNOWFLAKE_USER=your_username
SNOWFLAKE_ROLE=ACCOUNTADMIN
SNOWFLAKE_WAREHOUSE=AGENT_ROI_WH
SNOWFLAKE_DATABASE=AGENT_ROI_DEMO
SNOWFLAKE_SCHEMA=APP

# === Authentication (choose one) ===

# Option 1: Programmatic Access Token (PAT) directly
# SNOWFLAKE_PAT=your_programmatic_access_token

# Option 2: Token file path (generated by Snowflake CLI: `snow connection set-default`)
SNOWFLAKE_TOKEN_FILE=~/.snowflake/tokens/your_token_file

# === Next.js App (used by the frontend) ===
NEXT_PUBLIC_SNOWFLAKE_ACCOUNT=your-account-locator
NEXT_PUBLIC_AGENT_DATABASE=AGENT_ROI_DEMO
NEXT_PUBLIC_AGENT_SCHEMA=APP
NEXT_PUBLIC_AGENT_NAME=ROI_DEMO_AGENT
NEXT_PUBLIC_AGENT_WAREHOUSE=AGENT_ROI_WH

# === External Agent: Knowledge RAG (port 8000) ===
# These are read by external-agent/config.py
# Uses the same SNOWFLAKE_* vars above

# === External Agent: Local LLM (port 8001) ===
LLAMA_SERVER_URL=http://localhost:8080/v1
LLAMA_MODEL=qwen2.5-0.5b-instruct-q4_k_m.gguf
